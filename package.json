{
  "name": "freelancebill",
  "description": "Self-hosted business tracker for German freelancers and small businesses",
  "author": "Milan Ronnenberg",
  "license": "CC-BY-NC-4.0",
  "homepage": "https://github.com/milhero/freelancebill",
  "repository": {
    "type": "git",
    "url": "https://github.com/milhero/freelancebill.git"
  },
  "bugs": {
    "url": "https://github.com/milhero/freelancebill/issues"
  },
  "keywords": [
    "invoicing",
    "finance",
    "freelancer",
    "self-hosted",
    "german",
    "tax",
    "kleinunternehmer",
    "rechnung",
    "buchhaltung"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm --filter @freelancebill/server dev\" \"pnpm --filter @freelancebill/web dev\"",
    "build": "pnpm --filter @freelancebill/shared build && pnpm --filter @freelancebill/server build && pnpm --filter @freelancebill/web build",
    "build:shared": "pnpm --filter @freelancebill/shared build",
    "dev:server": "pnpm --filter @freelancebill/server dev",
    "dev:web": "pnpm --filter @freelancebill/web dev",
    "db:generate": "pnpm --filter @freelancebill/server db:generate",
    "db:migrate": "pnpm --filter @freelancebill/server db:migrate",
    "db:seed": "pnpm --filter @freelancebill/server db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild"
    ]
  }
}
